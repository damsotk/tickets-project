generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique @db.VarChar(255)
  password  String?  @db.VarChar(255) // null if entry by Discord
  name      String   @db.VarChar(100)
  avatar    String?  @db.VarChar(500) // URL avatar
  
  // Discord data (if entry from DS)
  discordId String?  @unique @db.VarChar(50)
  
  // Tokens
  refreshToken String? @db.Text
  
  role      UserRole @default(USER)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets   Ticket[]
  messages  Message[]
  closedTickets Ticket[] @relation("ClosedBy")
  
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Ticket {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(200)
  
  // Theme (complaint, lore, tech) - use ENUM
  category  TicketCategory 
  
  // Status of ticket
  status    TicketStatus @default(OPEN)
  
  // Date and user of close
  closedAt  DateTime?
  closedById String?
  closedBy  User?     @relation("ClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  
  // Connect with user who create ticket
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // Connect with messages
  messages  Message[]

  @@map("tickets")
}

enum TicketCategory {
  COMPLAINT
  LORE
  TECH
  OTHER
}

enum TicketStatus {
  OPEN
  CLOSED
}

model Message {
  id        String   @id @default(cuid())
  text      String   @db.VarChar(5000)

  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@map("messages")
}