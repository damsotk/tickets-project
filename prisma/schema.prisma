generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum TicketCategory {
  COMPLAINT
  LORE
  TECH
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique @db.VarChar(255)
  password        String?   @db.VarChar(255)
  name            String    @db.VarChar(100)
  avatar          String?   @db.VarChar(500)
  
  // Currency
  balance         Int       @default(0)
  
  // Discord data
  discordId       String?   @unique @db.VarChar(50)
  
  // Tokens
  refreshToken    String?   @db.Text
  
  role            UserRole  @default(USER)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tickets         Ticket[]
  closedTickets   Ticket[]  @relation("ClosedBy")
  messages        Message[]

  whitelistApplications  WhitelistApplication[]
  reviewedApplications   WhitelistApplication[]  @relation("ReviewedBy")
  
  @@map("users")
}

model Ticket {
  id        String         @id @default(cuid())
  title     String         @db.VarChar(200)
  category  TicketCategory 
  status    TicketStatus   @default(OPEN)
  
  // Close info
  closedAt  DateTime?
  closedById String?
  closedBy  User?          @relation("ClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  
  // Creator
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Messages
  messages  Message[]

  @@unique([userId, category, status], name: "unique_open_ticket_per_category")
  @@index([userId, status])
  
  @@map("tickets")
}

model Message {
  id        String   @id @default(cuid())
  text      String   @db.VarChar(5000)
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  authorId  String?                                          
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([authorId])
  
  @@map("messages")
}

enum WhitelistStatus {
  PENDING
  APPROVED
  REJECTED
}

model WhitelistApplication {
  id             String          @id @default(cuid())

  source         String          @db.VarChar(500)
  rpExperience   String          @db.VarChar(1000)
  plans          String?         @db.VarChar(2000)
  minecraftNick  String          @db.VarChar(100)
  discordNick    String          @db.VarChar(100)

  status         WhitelistStatus @default(PENDING)

  // Who want to join
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Viewed by
  reviewedAt     DateTime?
  reviewedById   String?
  reviewedBy     User?           @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewComment  String?         @db.VarChar(1000)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // One user one application
  @@unique([userId, status], name: "unique_pending_application")
  @@index([userId])
  @@index([status])

  @@map("whitelist_applications")
}